```mermaid
flowchart TB
{% for phase in phases -%}
{%- set inv0 = (phase.invocations[0] if phase.invocations else none) -%}
{%- set norm_id = phase.id|lower|replace('-', '')|replace(' ', '')|replace('_', '') -%}
{%- set norm_name = phase.name|lower|replace('-', '')|replace(' ', '')|replace('—', '')|replace('(', '')|replace(')', '')|replace('_', '') -%}
{%- set show_id = (norm_id not in norm_name) and (norm_name not in norm_id) -%}
{%- set meta_parts = [] -%}
{%- if phase.type -%}{%- set _ = meta_parts.append(phase.type) -%}{%- endif -%}
{%- if inv0 and inv0.model -%}{%- set _ = meta_parts.append(inv0.model) -%}{%- endif -%}
{%- if inv0 and inv0.effort and inv0.effort != 'inherit' -%}{%- set _ = meta_parts.append(inv0.effort + ' effort') -%}{%- endif -%}
{%- set opp_prefix = '' -%}
{%- if phase._opp and phase._opp.mark == 'opportunistic' -%}{%- set opp_prefix = '🧭 ' -%}
{%- elif phase._opp and phase._opp.mark == 'locked' -%}{%- set opp_prefix = '⛔ ' -%}
{%- endif -%}
{%- if phase.type == 'workflow_call' -%}
    {{ phase.id }}[["`🔗 **{{ phase.name }}**{% if show_id %}
*{{ phase.id }}*{% endif %}
_calls /{{ phase.workflow }}_`"]]:::workflow_call
{%- else -%}
    {{ phase.id }}["`**{{ opp_prefix }}{{ phase.name }}**{% if show_id %}
*{{ phase.id }}*{% endif %}{% if meta_parts %}
_{{ meta_parts|join(' · ') }}_{% endif %}`"]:::{{ phase.group }}
{%- endif %}
{% endfor %}
{%- if definition_phase %}
    DEFINITION[["`🎯 **Workflow output**
_returns: {{ definition_phase.emits | map(attribute='name') | join(', ') or '—' }}_`"]]:::definition
{%- endif %}
{% for phase in phases -%}
{%- for dep in phase.depends_on|default([]) %}
    {{ dep }} --> {{ phase.id }}
{%- endfor %}
{% endfor %}
{%- if definition_phase %}
{%- for dep in definition_phase.depends_on|default([]) %}
    {{ dep }} --> DEFINITION
{%- endfor %}
{%- endif %}
{%- for phase in phases -%}
{%- if phase._opp and phase._opp.mark == 'opportunistic' %}
    class {{ phase.id }} opportunistic
{%- elif phase._opp and phase._opp.mark == 'locked' %}
    class {{ phase.id }} opp_locked
{%- endif %}
{%- endfor %}
{%- if orchestration_overlay.loops or orchestration_overlay.branches %}
{% for lp in orchestration_overlay.loops -%}
subgraph loop_{{ loop.index }}["🔁 {{ lp.label }} (cap {{ lp.cap }})"]
{% for bid in lp.body_ids -%}
    {{ bid }}
{% endfor -%}
end
{% endfor -%}
{% for br in orchestration_overlay.branches -%}
{%- set br_id = "br_" ~ loop.index -%}
    {{ br_id }}{"{{ br.cond }}"}
{% for tid in br.then_ids -%}
    {{ br_id }} -->|true| {{ tid }}
{% endfor -%}
{% for eid in br.else_ids -%}
    {{ br_id }} -->|false| {{ eid }}
{% endfor -%}
{% endfor -%}
{%- endif %}
{% for gname in groups -%}
    classDef {{ gname }} fill:{{ group_colors[gname] }},stroke:#94a3b8,stroke-width:1px,color:#f1f5f9
{% endfor -%}
    classDef workflow_call fill:#312e81,stroke:#a78bfa,stroke-width:2px,color:#ede9fe
classDef definition fill:#0b2a1e,stroke:#4ade80,stroke-width:2px,color:#dcfce7
classDef opportunistic stroke:#f59e0b,stroke-width:2px,stroke-dasharray:5 4
classDef opp_locked stroke:#6b7280,stroke-width:1px,color:#9ca3af
```
